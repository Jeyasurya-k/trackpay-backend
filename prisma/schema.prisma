generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  username      String
  password      String?  // Optional because Apple users won't have a password
  appleId       String?  @unique // To store the unique Apple user identifier
  avatar        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  customers    Customer[]
  groups       Group[]
  groupMembers GroupMember[]

  @@index([username])
}

model Transaction {
  id          String   @id @default(uuid())
  type        String
  amount      Float
  category    String
  description String?
  date        DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, date])
  @@index([userId, type])
}

model Customer {
  id        String            @id @default(uuid())
  name      String
  location  String?
  phone     String
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchases Purchase[]
  payments  CustomerPayment[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([userId])
}

model Purchase {
  id          String   @id @default(uuid())
  amount      Float
  paid        Float    @default(0)
  description String?
  date        DateTime @default(now())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId])
  @@index([customerId, date])
}

model CustomerPayment {
  id          String   @id @default(uuid())
  amount      Float
  description String?
  date        DateTime @default(now())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId])
  @@index([customerId, date])
}

model Group {
  id          String   @id @default(uuid())
  name        String
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  members     GroupMember[]
  expenses    GroupExpense[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model GroupMember {
  id        String   @id @default(uuid())
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  expenses  GroupExpenseSplit[]
  paidExpenses GroupExpense[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupId])
  @@index([userId])
}

model GroupExpense {
  id              String   @id @default(uuid())
  groupId         String
  group           Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  amount          Float
  description     String?
  category        String?
  paidByMemberId  String
  paidByMember    GroupMember @relation(fields: [paidByMemberId], references: [id], onDelete: Restrict)
  splitType       String   @default("equal") // "equal" or "custom"
  date            DateTime @default(now())
  splits          GroupExpenseSplit[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([groupId])
  @@index([paidByMemberId])
}

model GroupExpenseSplit {
  id          String   @id @default(uuid())
  expenseId   String
  expense     GroupExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  memberId    String
  member      GroupMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  amount      Float
  status      String   @default("pending") // "pending" or "settled"
  settledDate DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([expenseId])
  @@index([memberId])
}